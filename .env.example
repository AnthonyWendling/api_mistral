# Obligatoire
MISTRAL_API_KEY=your_mistral_api_key

# Base vectorielle (persistance). Sur Railway, pointer vers le volume monté (ex. /data/chroma)
CHROMA_DATA_PATH=./data/chroma

# Optionnel
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=50
ALLOWED_ORIGINS=*
# Taille et chevauchement des chunks pour l'indexation
CHUNK_SIZE=512
CHUNK_OVERLAP=128
